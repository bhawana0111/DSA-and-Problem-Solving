#include <bits/stdc++.h>
using namespace std;
int main(){
    //check if the given number is a palindrome or not?
    int n=12321;
    int rev=0;
    int temp=n;
    while(temp!=0){
        rev=rev*10+temp%10;
        cout<<rev<<endl;
        temp=temp/10;
    }
    if (n==rev){
        cout<<"Yes"<<endl;
    }
    else{
        cout<<"No"<<endl;
    }




}
