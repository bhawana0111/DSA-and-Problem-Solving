#include <bits/stdc++.h>
 using namespace std;
 int main(){
    //to check if a number is armstrong or not// 
   //Logic:
// 1. Store the original number in a temporary variable.
// 2. Extract each digit using modulus (% 10).
// 3. Find the cube of each digit and add it to a sum variable.
// 4. Remove the last digit using division (/ 10).
// 5. Repeat until the number becomes 0.
// 6. Compare the sum with the original number.
// 7. If equal → Armstrong number, otherwise not.
    int n=153;
    int sum=0;
    int temp=n;
    while(temp!=0){
        int q=temp%10;
        sum=sum+pow(q,3);
        temp=temp/10;
    }
    if (n==sum){
        cout<<"Armstrong number";
    }
    else{
        cout<<"Not an Armstrog number";
    }
    return 0;

    
}
